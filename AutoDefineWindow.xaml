<Window x:Class="MouseTracker.AutoDefineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MouseTracker"
        mc:Ignorable="d"
        Title="Auto‑define Screen Size" Height="450" Width="800" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Calculated screen size:" FontWeight="Bold"/>
            <TextBlock x:Name="ScreenSizeText" Margin="0,5,0,15"/>

            <TextBlock Text="Aspect ratio:" FontWeight="Bold"/>
            <TextBlock x:Name="AspectRatioText" Margin="0,5,0,15"/>

            <Button Content="OK" Width="80" HorizontalAlignment="Right" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
