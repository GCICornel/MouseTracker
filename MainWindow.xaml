<Window x:Class="MouseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MouseTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="277" Width="431">
    <Grid>
        <Button Content="Start tracking (F9)" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="30" Width="150" Click="Start_Click"/>
        <Button Content="Stop tracking (F10)" HorizontalAlignment="Left" Margin="165,10,0,0" VerticalAlignment="Top" Height="30" Width="150" Click="Stop_Click"/>
        <Label Content="Selecte where your data is stored" HorizontalAlignment="Left" Margin="0,164,0,0" VerticalAlignment="Top"/>
        <Button Content="Select storage path" HorizontalAlignment="Left" Margin="10,195,0,0" VerticalAlignment="Top" Click="SelectStoragePath_Click"/>
        <Button Content="Visualize your stored data" HorizontalAlignment="Left" Margin="248,200,0,0" VerticalAlignment="Top" Click="VisualizeData_Click"/>
        <TextBlock x:Name="StatusTextBlock" HorizontalAlignment="Left" Margin="331,12,0,0" TextWrapping="Wrap" Text="Idle" VerticalAlignment="Top" Height="31" Width="59"/>
        <Button Content="Autodefine screen size" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top" Click="AutodefineScreenSize_Click"/>


    </Grid>
</Window>
